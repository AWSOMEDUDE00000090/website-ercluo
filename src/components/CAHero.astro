---
// Cellular-automata hero: the heading is rasterized onto a grid of cells.
// Idle, every cell relaxes toward the glyph pattern (the attractor), so the
// text is crisp. Near the cursor, cells stochastically migrate their "ink"
// to neighboring cells with an outward bias, so the letters disperse
// cell-by-cell; when the cursor leaves they settle back home.
//
// The real text lives in the <h1> below. The canvas is a purely visual
// layer that replaces it only when JS runs and motion is allowed.
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="ca-hero" data-ca-hero data-text={text}>
  <h1 class="ca-hero-text">{text}</h1>
  <canvas class="ca-hero-canvas" aria-hidden="true"></canvas>
</div>

<script>
  /* ---------------- Tunables ---------------- */
  const CELL_SIZE = 5; // px per cell (CSS pixels)
  const CELL_GAP = 1; // px of breathing room between drawn cells
  const FONT_WEIGHT = 600;
  const TEXT_WIDTH_FRACTION = 0.9; // max fraction of hero width the text may fill
  const TEXT_HEIGHT_FRACTION = 0.62; // max fraction of hero height
  const INFLUENCE_RADIUS = 130; // px around the cursor that disturbs cells
  const MIGRATION_RATE = 0.38; // fraction of a cell's ink that migrates per step at full influence
  const OUTWARD_BIAS = 0.65; // 0 = random walk, 1 = always flee the cursor
  const RELAX_RATE = 0.075; // per-step pull back toward the glyph pattern
  const STEP_MS = 1000 / 60; // fixed CA timestep
  const ALPHA_LEVELS = 8; // quantized opacity levels (chunky, digital feel)
  const MIN_DRAW_DENSITY = 0.06; // cells fainter than this aren't drawn

  class CAHero {
    private root: HTMLElement;
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private text: string;

    private gw = 0; // grid width/height in cells
    private gh = 0;
    private target = new Float32Array(0); // glyph pattern (the attractor)
    private state = new Float32Array(0); // live ink density, 0..1
    private next = new Float32Array(0);

    private mouseX = -1e6; // grid coordinates; far away = inactive
    private mouseY = -1e6;
    private pointerActive = false;

    private raf = 0;
    private lastTime = 0;
    private acc = 0;
    private inView = true;
    private running = false;
    private ink = "#000000";

    private cleanups: (() => void)[] = [];

    constructor(root: HTMLElement) {
      this.root = root;
      this.canvas = root.querySelector("canvas")!;
      this.ctx = this.canvas.getContext("2d")!;
      this.text = root.dataset.text ?? "";

      this.readInkColor();
      this.activate();
      this.bindEvents();
    }

    /**
     * Rasterize and take over from the static h1 — but only once the hero
     * actually has layout. If it doesn't yet (hidden tab, display:none),
     * the static text stays visible and the ResizeObserver retries.
     */
    private activate() {
      if (!this.rebuildGrid()) return;
      // Paint the idle state immediately — RAF may be throttled (e.g. in a
      // background tab), and the h1 is hidden as soon as the class lands.
      this.render();
      this.root.classList.add("is-animated");
      this.start();
    }

    private readInkColor() {
      this.ink = getComputedStyle(document.documentElement)
        .getPropertyValue("--text")
        .trim();
    }

    /** Rasterize the heading onto the grid and (re)size the canvas. */
    private rebuildGrid(): boolean {
      const rect = this.root.getBoundingClientRect();
      if (rect.width < 10 || rect.height < 10) return false;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      this.canvas.width = Math.round(rect.width * dpr);
      this.canvas.height = Math.round(rect.height * dpr);
      this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      this.gw = Math.max(1, Math.floor(rect.width / CELL_SIZE));
      this.gh = Math.max(1, Math.floor(rect.height / CELL_SIZE));
      const n = this.gw * this.gh;
      this.target = new Float32Array(n);
      this.state = new Float32Array(n);
      this.next = new Float32Array(n);

      // Draw the text at grid resolution; each pixel becomes one cell.
      const off = document.createElement("canvas");
      off.width = this.gw;
      off.height = this.gh;
      const octx = off.getContext("2d", { willReadFrequently: true })!;
      const family = getComputedStyle(this.root).getPropertyValue(
        "--font-display",
      );

      // Fit the text: measure at a reference size, then scale to the box.
      const refSize = 100;
      octx.font = `${FONT_WEIGHT} ${refSize}px ${family}`;
      const m = octx.measureText(this.text);
      const refH =
        m.actualBoundingBoxAscent + m.actualBoundingBoxDescent || refSize;
      const scale = Math.min(
        (this.gw * TEXT_WIDTH_FRACTION) / Math.max(1, m.width),
        (this.gh * TEXT_HEIGHT_FRACTION) / refH,
      );
      octx.font = `${FONT_WEIGHT} ${refSize * scale}px ${family}`;
      octx.textAlign = "center";
      octx.textBaseline = "middle";
      octx.fillStyle = "#fff";
      octx.fillText(this.text, this.gw / 2, this.gh / 2);

      // Alpha channel → target density (anti-aliased edges stay fractional).
      const px = octx.getImageData(0, 0, this.gw, this.gh).data;
      for (let i = 0; i < n; i++) this.target[i] = px[i * 4 + 3]! / 255;
      this.state.set(this.target);
      return true;
    }

    /** One fixed-timestep CA update. */
    private step() {
      const { gw, gh, state, next, target } = this;
      next.set(state);

      const radiusCells = INFLUENCE_RADIUS / CELL_SIZE;
      const r2 = radiusCells * radiusCells;
      const mx = this.mouseX;
      const my = this.mouseY;

      for (let y = 0; y < gh; y++) {
        const dy = y - my;
        for (let x = 0; x < gw; x++) {
          const i = y * gw + x;
          const dx = x - mx;
          const d2 = dx * dx + dy * dy;

          // Influence falls off smoothly from 1 at the cursor to 0 at the radius.
          let f = 0;
          if (this.pointerActive && d2 < r2) {
            const t = 1 - Math.sqrt(d2) / radiusCells;
            f = t * t;
          }

          const s = state[i]!;

          if (f > 0 && s > 0.002) {
            // Migrate a parcel of ink to one neighbor, biased away from the
            // cursor. Mass-conserving: what leaves this cell lands next door.
            const amount = s * MIGRATION_RATE * f;
            const d = Math.sqrt(d2) || 1;
            const away = Math.random() < OUTWARD_BIAS;
            let nx: number, ny: number;
            if (away) {
              nx = x + Math.round(dx / d + (Math.random() - 0.5));
              ny = y + Math.round(dy / d + (Math.random() - 0.5));
            } else {
              nx = x + ((Math.random() * 3) | 0) - 1;
              ny = y + ((Math.random() * 3) | 0) - 1;
            }
            if (nx >= 0 && nx < gw && ny >= 0 && ny < gh && (nx !== x || ny !== y)) {
              next[i]! -= amount;
              next[ny * gw + nx]! += amount;
            }
          }

          // Relax toward the glyph pattern, gated by (1 - influence) so
          // cells under the cursor stay free and distant cells snap home.
          const relax = RELAX_RATE * (1 - f);
          if (relax > 0) {
            next[i]! += relax * (target[i]! - next[i]!);
          }
        }
      }

      // Clamp and swap buffers.
      for (let i = 0; i < next.length; i++) {
        const v = next[i]!;
        next[i] = v < 0 ? 0 : v > 1 ? 1 : v;
      }
      this.next = this.state;
      this.state = next;
    }

    // Cell indices grouped by quantized alpha, rebuilt each frame.
    private buckets: number[][] = Array.from(
      { length: ALPHA_LEVELS },
      () => [],
    );

    private render() {
      const { ctx, gw, state, buckets } = this;
      ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
      ctx.fillStyle = this.ink;

      // Single pass: bucket cells by quantized alpha, then draw each bucket
      // with one globalAlpha change (fillRect batching).
      for (const b of buckets) b.length = 0;
      for (let i = 0; i < state.length; i++) {
        const s = state[i]!;
        if (s < MIN_DRAW_DENSITY) continue;
        const q = Math.min(ALPHA_LEVELS - 1, (s * ALPHA_LEVELS) | 0);
        buckets[q]!.push(i);
      }

      const size = CELL_SIZE - CELL_GAP;
      for (let level = 0; level < ALPHA_LEVELS; level++) {
        const bucket = buckets[level]!;
        if (bucket.length === 0) continue;
        ctx.globalAlpha = (level + 1) / ALPHA_LEVELS;
        for (const i of bucket) {
          const x = i % gw;
          const y = (i / gw) | 0;
          ctx.fillRect(x * CELL_SIZE, y * CELL_SIZE, size, size);
        }
      }
      ctx.globalAlpha = 1;
    }

    private loop = (now: number) => {
      if (!this.running) return;
      this.raf = requestAnimationFrame(this.loop);
      // Fixed-timestep updates keep the CA speed framerate-independent.
      this.acc = Math.min(this.acc + (now - this.lastTime), 100);
      this.lastTime = now;
      let stepped = false;
      while (this.acc >= STEP_MS) {
        this.step();
        this.acc -= STEP_MS;
        stepped = true;
      }
      if (stepped) this.render();
    };

    private start() {
      if (this.running || !this.inView) return;
      this.running = true;
      this.lastTime = performance.now();
      this.acc = STEP_MS; // render immediately
      this.raf = requestAnimationFrame(this.loop);
    }

    private stop() {
      this.running = false;
      cancelAnimationFrame(this.raf);
    }

    private bindEvents() {
      const on = (
        target: EventTarget,
        type: string,
        fn: (e: any) => void,
        opts?: AddEventListenerOptions,
      ) => {
        target.addEventListener(type, fn, opts);
        this.cleanups.push(() => target.removeEventListener(type, fn));
      };

      const updatePointer = (e: PointerEvent) => {
        const rect = this.canvas.getBoundingClientRect();
        this.mouseX = (e.clientX - rect.left) / CELL_SIZE;
        this.mouseY = (e.clientY - rect.top) / CELL_SIZE;
        this.pointerActive = true;
      };
      // pointermove covers mouse and touch-drag; pointerdown covers taps.
      on(this.root, "pointermove", updatePointer, { passive: true });
      on(this.root, "pointerdown", updatePointer, { passive: true });
      const release = () => {
        this.pointerActive = false;
      };
      on(this.root, "pointerleave", release);
      on(this.root, "pointercancel", release);
      // On touch devices, lifting the finger ends the disturbance.
      on(this.root, "pointerup", (e: PointerEvent) => {
        if (e.pointerType !== "mouse") release();
      });

      // Pause the simulation while the hero is off-screen.
      const io = new IntersectionObserver(([entry]) => {
        this.inView = entry?.isIntersecting ?? true;
        if (this.inView) this.start();
        else this.stop();
      });
      io.observe(this.root);
      this.cleanups.push(() => io.disconnect());

      // Re-rasterize on resize (debounced) and re-ink on theme change.
      let resizeTimer = 0;
      const ro = new ResizeObserver(() => {
        window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          if (this.root.classList.contains("is-animated")) {
            if (this.rebuildGrid()) this.render();
          } else {
            this.activate(); // first layout arrived late (e.g. hidden tab)
          }
        }, 150);
      });
      ro.observe(this.root);
      this.cleanups.push(() => ro.disconnect());

      const mo = new MutationObserver(() => {
        this.readInkColor();
        this.render();
      });
      mo.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });
      this.cleanups.push(() => mo.disconnect());
    }

    destroy() {
      this.stop();
      for (const fn of this.cleanups) fn();
      this.cleanups = [];
      this.root.classList.remove("is-animated");
    }
  }

  function init() {
    const root = document.querySelector<HTMLElement>("[data-ca-hero]");
    if (!root) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let instance: CAHero | null = null;

    const apply = () => {
      if (reduceMotion.matches) {
        instance?.destroy();
        instance = null;
      } else if (!instance) {
        instance = new CAHero(root);
      }
    };

    // Wait for the display font so the rasterized glyphs match the h1.
    document.fonts.ready.then(apply);
    reduceMotion.addEventListener("change", apply);
  }

  init();
</script>

<style>
  .ca-hero {
    position: relative;
    height: clamp(300px, 48vh, 520px);
    touch-action: pan-y; /* keep page scroll working over the canvas */
  }

  .ca-hero-text {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    text-align: center;
    font-size: clamp(3rem, 11vw, 7.5rem);
    font-weight: 600;
    padding-inline: var(--space-page);
  }

  .ca-hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
  }

  /* Once the simulation owns the pixels, hide the h1 visually but keep it
     in the accessibility tree and in the document for crawlers. */
  .ca-hero.is-animated .ca-hero-text {
    opacity: 0;
  }

  .ca-hero.is-animated .ca-hero-canvas {
    display: block;
  }
</style>
