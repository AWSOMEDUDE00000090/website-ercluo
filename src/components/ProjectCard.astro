---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, summary, period, tech, coverImage, coverImageAlt, featured } =
  project.data;
---

<article class:list={["card", "project-card"]}>
  {
    coverImage && (
      <a
        href={`/projects/${project.id}/`}
        class="cover"
        tabindex="-1"
        aria-hidden="true"
      >
        <Image
          src={coverImage}
          alt={coverImageAlt ?? ""}
          width={720}
          densities={[1, 2]}
        />
      </a>
    )
  }
  <div class="body">
    <div class="meta">
      <span>{period}</span>
      {featured && <span class="featured-mark">Featured</span>}
    </div>
    <h3><a href={`/projects/${project.id}/`}>{title}</a></h3>
    <p>{summary}</p>
    {
      tech.length > 0 && (
        <ul class="tags" aria-label="Technologies">
          {tech.map((t) => (
            <li>
              <span class="tag">{t}</span>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .project-card {
    height: 100%;
  }

  .cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    flex: 1;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .featured-mark {
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  h3 {
    font-size: var(--text-lg);
  }

  /* Stretch the title link over the whole card for a bigger hit target */
  h3 a {
    color: var(--text);
  }

  h3 a::after {
    content: "";
    position: absolute;
    inset: 0;
  }

  h3 a:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .project-card {
    position: relative;
  }

  p {
    color: var(--text-muted);
    font-size: var(--text-sm);
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin-top: 0.5rem;
    /* Sit above the stretched link so tag text stays selectable */
    position: relative;
    z-index: 1;
  }
</style>
