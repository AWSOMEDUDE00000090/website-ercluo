---
import { SITE_TITLE, SOCIALS } from "@/consts";

const year = new Date().getFullYear();

const links = [
  { href: SOCIALS.github, label: "GitHub" },
  { href: SOCIALS.youtube, label: "YouTube" },
  { href: SOCIALS.instagram, label: "Instagram" },
  { href: SOCIALS.email, label: "Email" },
  { href: "/rss.xml", label: "RSS" },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="copyright">© {year} {SITE_TITLE}</p>
    <nav aria-label="Social links">
      <ul>
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              {...href.startsWith("http")
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {}}
            >
              {label}
            </a>
          </li>
        ))
      }
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem 2rem;
    padding-block: 2rem;
    font-size: var(--text-sm);
  }

  .copyright {
    color: var(--text-muted);
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
  }

  a {
    color: var(--text-muted);
  }

  a:hover {
    color: var(--accent);
  }
</style>
