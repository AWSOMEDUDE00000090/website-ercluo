---
interface Props {
  prevUrl?: string;
  nextUrl?: string;
  current: number;
  total: number;
}

const { prevUrl, nextUrl, current, total } = Astro.props;
---

{
  total > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {prevUrl ? (
        <a href={prevUrl} class="button">
          ← Newer
        </a>
      ) : (
        <span />
      )}
      <span class="status">
        Page {current} of {total}
      </span>
      {nextUrl ? (
        <a href={nextUrl} class="button">
          Older →
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}

<style>
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
  }

  .status {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
</style>
