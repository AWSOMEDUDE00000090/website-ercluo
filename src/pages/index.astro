---
import { getCollection } from "astro:content";
import Shell from "~/layouts/Shell.astro";
import GridHero from "~/components/GridHero.astro";
import ProjectTile from "~/components/ProjectTile.astro";
import PostRow from "~/components/PostRow.astro";
import { SITE } from "~/site";
import { byNewest, byProjectRank, published } from "~/lib";

const featured = byProjectRank(
  await getCollection("projects", (p) => published(p) && p.data.featured),
).slice(0, 3);

const recent = byNewest(await getCollection("blog", published)).slice(0, 3);
---

<Shell title={SITE.name} description={SITE.description}>
  <GridHero text={SITE.heroText} />

  <div class="wrap">
    <p class="intro">{SITE.tagline}</p>

    <section aria-labelledby="h-projects">
      <header class="rule-head">
        <span class="kicker" id="h-projects">Featured projects</span>
        <a class="aside" href="/projects/">All projects →</a>
      </header>
      <div class="tiles">
        {featured.map((project) => <ProjectTile project={project} />)}
      </div>
    </section>

    <section aria-labelledby="h-posts">
      <header class="rule-head">
        <span class="kicker" id="h-posts">Latest writing</span>
        <a class="aside" href="/blog/">All posts →</a>
      </header>
      <div class="rows">
        {recent.map((post) => <PostRow post={post} />)}
      </div>
    </section>
  </div>
</Shell>

<style>
  .intro {
    font-family: var(--font-head);
    font-size: var(--size-3);
    line-height: 1.4;
    max-width: 34ch;
    padding-block: clamp(2.5rem, 6vh, 4rem);
  }

  section {
    margin-bottom: 4.5rem;
  }

  .tiles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 2rem;
  }

  .rows > :global(* + *) {
    border-top: 1px solid var(--line);
  }
</style>
