---
import { getEntry, render } from "astro:content";
import Shell from "~/layouts/Shell.astro";

// Body lives in src/content/pages/about.md — that's the file to edit.
const about = await getEntry("pages", "about");
if (!about) throw new Error("src/content/pages/about.md is missing");
const { Content } = await render(about);
---

<Shell title={about.data.title} description={about.data.description}>
  <div class="wrap wrap-text">
    <header class="page-head">
      <span class="kicker">Person</span>
      <h1>{about.data.title}</h1>
    </header>
    <div class="prose about">
      <Content />
    </div>
  </div>
</Shell>

<style>
  /* First image in the body = portrait slot; keep it portrait-sized. */
  .about :global(> p:first-of-type img) {
    max-width: min(280px, 65%);
    margin-inline: 0;
  }
</style>
