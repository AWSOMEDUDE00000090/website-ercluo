---
import Shell from "~/layouts/Shell.astro";
---

<Shell title="404" description="Page not found.">
  <div class="wrap lost">
    <p class="kicker">Error 404</p>
    <h1>No such page.</h1>
    <p class="why">
      Moved, renamed, or never existed. The nav above has everything that
      does.
    </p>
    <p class="links">
      <a class="btn btn-solid" href="/">Home</a>
      <a class="btn" href="/projects/">Projects</a>
      <a class="btn" href="/blog/">Blog</a>
    </p>
  </div>
</Shell>

<style>
  .lost {
    padding-block: clamp(4rem, 18vh, 9rem) 3rem;
    max-width: 36rem;
  }

  h1 {
    font-size: var(--size-5);
    margin-block: 0.75rem;
  }

  .why {
    color: var(--ink-2);
  }

  .links {
    display: flex;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
