---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Shell from "~/layouts/Shell.astro";
import PostRow from "~/components/PostRow.astro";
import { byNewest, published, tagSlug } from "~/lib";

export const getStaticPaths = (async () => {
  const posts = byNewest(await getCollection("blog", published));
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag: tagSlug(tag) },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---

<Shell title={`Tag: ${tag}`} description={`Posts tagged “${tag}”.`}>
  <div class="wrap wrap-text">
    <header class="page-head">
      <span class="kicker">Tag</span>
      <h1>{tag}</h1>
      <p class="lede">
        {posts.length}
        {posts.length === 1 ? "post" : "posts"} · <a href="/blog/">all posts</a>
      </p>
    </header>

    <div class="rows">
      {posts.map((post) => <PostRow post={post} />)}
    </div>
  </div>
</Shell>

<style>
  .lede a {
    color: var(--copper);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rows > :global(* + *) {
    border-top: 1px solid var(--line);
  }
</style>
