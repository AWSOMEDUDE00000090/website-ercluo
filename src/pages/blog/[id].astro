---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { isPublished, readingTime, slugifyTag, sortPostsNewestFirst } from "@/utils";

export const getStaticPaths = (async () => {
  const posts = sortPostsNewestFirst(await getCollection("blog", isPublished));
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: {
      post,
      // posts are newest-first: "newer" is the previous index
      newer: posts[i - 1],
      older: posts[i + 1],
    },
  }));
}) satisfies GetStaticPaths;

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, heroImage, heroImageAlt } =
  post.data;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  image={heroImage?.src}
>
  <article class="container container--narrow">
    <header class="page-header">
      <p class="post-meta">
        <FormattedDate date={pubDate} />
        <span aria-hidden="true">·</span>
        <span>{readingTime(post.body)}</span>
        {
          updatedDate && (
            <span class="updated">
              Updated <FormattedDate date={updatedDate} />
            </span>
          )
        }
      </p>
      <h1>{title}</h1>
      {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => (
              <li>
                <a class="tag" href={`/blog/tags/${slugifyTag(tag)}/`}>
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      heroImage && (
        <Image
          src={heroImage}
          alt={heroImageAlt ?? ""}
          width={1400}
          class="hero-image"
        />
      )
    }

    <div class="prose">
      <Content />
    </div>

    <nav class="post-nav" aria-label="Adjacent posts">
      {
        older ? (
          <a href={`/blog/${older.id}/`} class="post-nav-link">
            <span class="eyebrow">← Older</span>
            <span>{older.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        newer ? (
          <a href={`/blog/${newer.id}/`} class="post-nav-link is-next">
            <span class="eyebrow">Newer →</span>
            <span>{newer.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <p class="back-link"><a href="/blog/">← Back to blog</a></p>
  </article>
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .updated {
    font-style: italic;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin-top: 1rem;
  }

  .hero-image {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--text);
    font-weight: 500;
  }

  .post-nav-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .post-nav-link.is-next {
    text-align: right;
    align-items: flex-end;
  }

  .back-link {
    margin-top: 2.5rem;
    font-size: var(--text-sm);
  }
</style>
