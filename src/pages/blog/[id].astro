---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Shell from "~/layouts/Shell.astro";
import { byNewest, fmtDate, minutesToRead, published, tagSlug } from "~/lib";

export const getStaticPaths = (async () => {
  const posts = byNewest(await getCollection("blog", published));
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: { post, newer: posts[i - 1], older: posts[i + 1] },
  }));
}) satisfies GetStaticPaths;

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const d = post.data;
---

<Shell
  title={d.title}
  description={d.description}
  article
  image={d.heroImage?.src}
>
  <article class="wrap wrap-text">
    <header class="page-head">
      <p class="meta">
        <time datetime={d.pubDate.toISOString()}>{fmtDate(d.pubDate)}</time>
        <span>·</span>
        <span>{minutesToRead(post.body)}</span>
        {
          d.updatedDate && (
            <span class="upd">
              updated <time datetime={d.updatedDate.toISOString()}>{fmtDate(d.updatedDate)}</time>
            </span>
          )
        }
      </p>
      <h1>{d.title}</h1>
      {
        d.tags.length > 0 && (
          <ul class="tag-row" aria-label="Tags">
            {d.tags.map((tag) => (
              <li>
                <a class="tag" href={`/blog/tags/${tagSlug(tag)}/`}>
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      d.heroImage && (
        <Image class="hero-img" src={d.heroImage} alt={d.heroImageAlt} width={1360} />
      )
    }

    <div class="prose">
      <Content />
    </div>

    <nav class="adjacent" aria-label="More posts">
      {
        older ? (
          <a href={`/blog/${older.id}/`}>
            <span class="kicker">← Older</span>
            <span class="t">{older.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        newer ? (
          <a class="next" href={`/blog/${newer.id}/`}>
            <span class="kicker">Newer →</span>
            <span class="t">{newer.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <p class="back"><a href="/blog/">← Back to blog</a></p>
  </article>
</Shell>

<style>
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--size-0);
    color: var(--ink-2);
    margin-bottom: 0.4rem;
  }

  .upd {
    font-style: italic;
  }

  .page-head .tag-row {
    margin-top: 1.1rem;
  }

  .hero-img {
    border: 1px solid var(--line);
    margin-bottom: 2.5rem;
  }

  .adjacent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-top: 4rem;
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }

  .adjacent a {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .adjacent .t {
    font-family: var(--font-head);
    font-weight: 500;
  }

  .adjacent a:hover .t {
    color: var(--copper);
  }

  .next {
    text-align: right;
    align-items: flex-end;
  }

  .back {
    margin-top: 2.5rem;
    font-size: var(--size-1);
  }

  .back a {
    color: var(--ink-2);
  }

  .back a:hover {
    color: var(--copper);
  }
</style>
