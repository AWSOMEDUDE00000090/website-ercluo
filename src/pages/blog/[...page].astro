---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import Pagination from "@/components/Pagination.astro";
import { POSTS_PER_PAGE } from "@/consts";
import { isPublished, slugifyTag, sortPostsNewestFirst } from "@/utils";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = sortPostsNewestFirst(await getCollection("blog", isPublished));
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const allTags = [
  ...new Set(
    (await getCollection("blog", isPublished)).flatMap((p) => p.data.tags),
  ),
].sort();
---

<BaseLayout
  title="Blog"
  description="Writing on embedded systems, 3D printing, video, and whatever's on the bench."
>
  <div class="container container--narrow">
    <header class="page-header">
      <h1>Blog</h1>
      <p>
        Notes from the bench — embedded systems, fabrication, and the
        occasional detour.
      </p>
    </header>

    {
      allTags.length > 0 && (
        <nav class="tag-nav" aria-label="Filter by tag">
          <ul>
            {allTags.map((tag) => (
              <li>
                <a class="tag" href={`/blog/tags/${slugifyTag(tag)}/`}>
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="post-list">
      {page.data.map((post) => <PostCard post={post} />)}
    </div>

    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      current={page.currentPage}
      total={page.lastPage}
    />
  </div>
</BaseLayout>

