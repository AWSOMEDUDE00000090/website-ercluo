---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Shell from "~/layouts/Shell.astro";
import PostRow from "~/components/PostRow.astro";
import Pager from "~/components/Pager.astro";
import { SITE } from "~/site";
import { byNewest, published, tagSlug } from "~/lib";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = byNewest(await getCollection("blog", published));
  return paginate(posts, { pageSize: SITE.postsPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const tags = [
  ...new Set(
    (await getCollection("blog", published)).flatMap((p) => p.data.tags),
  ),
].sort();
---

<Shell
  title="Blog"
  description="Build logs and field notes — embedded systems, fabrication, photography gear, and the web."
>
  <div class="wrap wrap-text">
    <header class="page-head">
      <span class="kicker">Writing</span>
      <h1>Blog</h1>
      <p class="lede">
        Build logs and field notes. Mostly things I wish I'd found on someone
        else's site before I started.
      </p>
    </header>

    {
      tags.length > 0 && (
        <nav aria-label="Browse by tag">
          <ul class="tag-row">
            {tags.map((tag) => (
              <li>
                <a class="tag" href={`/blog/tags/${tagSlug(tag)}/`}>
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="rows">
      {page.data.map((post) => <PostRow post={post} />)}
    </div>

    <Pager
      prev={page.url.prev}
      next={page.url.next}
      page={page.currentPage}
      pages={page.lastPage}
    />
  </div>
</Shell>

<style>
  nav {
    margin-bottom: 1.25rem;
  }

  .rows > :global(* + *) {
    border-top: 1px solid var(--line);
  }
</style>
