---
import { getCollection } from "astro:content";
import Shell from "~/layouts/Shell.astro";
import ProjectTile from "~/components/ProjectTile.astro";
import { byProjectRank, published, tagSlug } from "~/lib";

const projects = byProjectRank(await getCollection("projects", published));
const techs = [...new Set(projects.flatMap((p) => p.data.tech))].sort();
---

<Shell
  title="Projects"
  description="Hardware and software builds, documented: embedded systems, 3D-printed tools, and the glue between them."
>
  <div class="wrap">
    <header class="page-head">
      <span class="kicker">Work</span>
      <h1>Projects</h1>
      <p class="lede">
        Built, broken, rebuilt, and written up. The write-ups include the
        mistakes — that's usually the useful part.
      </p>
    </header>

    {
      techs.length > 0 && (
        <nav aria-label="Filter by technology">
          <ul class="tag-row">
            <li>
              <span class="tag is-on">All</span>
            </li>
            {techs.map((tech) => (
              <li>
                <a class="tag" href={`/projects/tech/${tagSlug(tech)}/`}>
                  {tech}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="tiles">
      {projects.map((project) => <ProjectTile project={project} />)}
    </div>
  </div>
</Shell>

<style>
  nav {
    margin-bottom: 2rem;
  }

  .tiles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 2rem;
  }
</style>
