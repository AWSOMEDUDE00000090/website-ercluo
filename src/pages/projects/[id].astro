---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Shell from "~/layouts/Shell.astro";
import { published, tagSlug } from "~/lib";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects", published);
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const LINK_LABELS = {
  repo: "Source",
  live: "Live",
  demo: "Demo",
  video: "Video",
} as const;
const links = (Object.keys(LINK_LABELS) as (keyof typeof LINK_LABELS)[])
  .filter((k) => d.links[k])
  .map((k) => ({ label: LINK_LABELS[k], href: d.links[k]! }));
---

<Shell
  title={d.title}
  description={d.summary}
  article
  image={d.coverImage?.src}
>
  <article class="wrap wrap-text">
    <header class="page-head">
      <p class="meta">
        <span>{d.period}</span>
        {d.role && <span>· {d.role}</span>}
      </p>
      <h1>{d.title}</h1>
      <p class="lede">{d.summary}</p>
      {
        d.tech.length > 0 && (
          <ul class="tag-row" aria-label="Technologies">
            {d.tech.map((t) => (
              <li>
                <a class="tag" href={`/projects/tech/${tagSlug(t)}/`}>
                  {t}
                </a>
              </li>
            ))}
          </ul>
        )
      }
      {
        links.length > 0 && (
          <p class="links">
            {links.map(({ label, href }) => (
              <a class="btn" href={href} target="_blank" rel="noopener noreferrer">
                {label} ↗
              </a>
            ))}
          </p>
        )
      }
    </header>

    {
      d.coverImage && (
        <Image class="cover" src={d.coverImage} alt={d.coverImageAlt} width={1360} />
      )
    }

    <div class="prose">
      <Content />
    </div>

    {
      d.gallery.length > 0 && (
        <section class="gallery" aria-label="Gallery">
          <header class="rule-head">
            <span class="kicker">Gallery</span>
          </header>
          <div class="grid">
            {d.gallery.map(({ src, alt }) => (
              <Image src={src} alt={alt} width={800} />
            ))}
          </div>
        </section>
      )
    }

    <p class="back"><a href="/projects/">← Back to projects</a></p>
  </article>
</Shell>

<style>
  .meta {
    font-family: var(--font-mono);
    font-size: var(--size-0);
    color: var(--ink-2);
    margin-bottom: 0.4rem;
    display: flex;
    gap: 0.5rem;
  }

  .page-head .tag-row {
    margin-top: 1.1rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .cover {
    border: 1px solid var(--line);
    margin-bottom: 2.5rem;
  }

  .gallery {
    margin-top: 4rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1rem;
  }

  .grid img {
    border: 1px solid var(--line);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .back {
    margin-top: 3rem;
    font-size: var(--size-1);
  }

  .back a {
    color: var(--ink-2);
  }

  .back a:hover {
    color: var(--copper);
  }
</style>
