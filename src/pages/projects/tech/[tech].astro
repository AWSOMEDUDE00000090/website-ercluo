---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { isPublished, slugifyTag, sortProjects } from "@/utils";

export const getStaticPaths = (async () => {
  const projects = sortProjects(await getCollection("projects", isPublished));
  const techs = [...new Set(projects.flatMap((p) => p.data.tech))];
  return techs.map((tech) => ({
    params: { tech: slugifyTag(tech) },
    props: {
      tech,
      projects: projects.filter((p) => p.data.tech.includes(tech)),
    },
  }));
}) satisfies GetStaticPaths;

const { tech, projects } = Astro.props;
---

<BaseLayout
  title={`Projects using ${tech}`}
  description={`Projects built with ${tech}.`}
>
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Technology</p>
      <h1>{tech}</h1>
      <p>
        {projects.length} {projects.length === 1 ? "project" : "projects"} ·
        <a href="/projects/">all projects</a>
      </p>
    </header>

    <div class="project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</BaseLayout>
