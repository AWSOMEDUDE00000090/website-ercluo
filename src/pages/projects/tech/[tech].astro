---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Shell from "~/layouts/Shell.astro";
import ProjectTile from "~/components/ProjectTile.astro";
import { byProjectRank, published, tagSlug } from "~/lib";

export const getStaticPaths = (async () => {
  const projects = byProjectRank(await getCollection("projects", published));
  const techs = [...new Set(projects.flatMap((p) => p.data.tech))];
  return techs.map((tech) => ({
    params: { tech: tagSlug(tech) },
    props: { tech, projects: projects.filter((p) => p.data.tech.includes(tech)) },
  }));
}) satisfies GetStaticPaths;

const { tech, projects } = Astro.props;
---

<Shell title={`Projects: ${tech}`} description={`Projects built with ${tech}.`}>
  <div class="wrap">
    <header class="page-head">
      <span class="kicker">Technology</span>
      <h1>{tech}</h1>
      <p class="lede">
        {projects.length}
        {projects.length === 1 ? "project" : "projects"} ·
        <a href="/projects/">all projects</a>
      </p>
    </header>

    <div class="tiles">
      {projects.map((project) => <ProjectTile project={project} />)}
    </div>
  </div>
</Shell>

<style>
  .lede a {
    color: var(--copper);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tiles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 2rem;
  }
</style>
